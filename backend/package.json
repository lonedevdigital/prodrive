{
  "name": "backend",
  "version": "1.0.0",
  "description": "Fastify backend for cloud drive app",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "dotenv -e ../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev --name init",
    "prisma:push": "dotenv -e ../.env -- prisma db push"
  },
  "keywords": [
    "fastify",
    "cloudflare-r2",
    "drive"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/lib-storage": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.16.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
