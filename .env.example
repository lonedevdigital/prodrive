PORT=4000
FRONTEND_ORIGIN=https://app.example.com
JWT_SECRET=change-this-secret
DATABASE_URL=mysql://drive_user:drive_password@mysql:3306/drive_db

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=drive_db
MYSQL_USER=drive_user
MYSQL_PASSWORD=drive_password

R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=your-bucket-name
UPLOAD_MAX_FILE_SIZE_MB=5120
UPLOAD_REQUEST_TIMEOUT_MS=1800000
R2_MULTIPART_PART_SIZE_MB=16
R2_MULTIPART_QUEUE_SIZE=4
# Optional legacy alias (tidak perlu kalau R2_BUCKET sudah diisi):
# R2_BUCKET_NAME=your-bucket-name
PUBLIC_SHARE_BASE_URL=

VITE_API_BASE_URL=https://api.example.com
